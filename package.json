{
	"name": "context-bro",
	"version": "0.1.0",
	"description": "Browser context provider for AI agents — Web Clipper for AI",
	"type": "module",
	"scripts": {
		"dev": "wxt",
		"dev:firefox": "wxt --browser firefox",
		"build": "wxt build",
		"build:firefox": "wxt build --browser firefox",
		"zip": "wxt zip",
		"zip:firefox": "wxt zip --browser firefox",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"typecheck": "tsc --noEmit"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/DoodleBears/ContextBro.git"
	},
	"keywords": [
		"browser-extension",
		"web-clipper",
		"ai-agent",
		"context-provider",
		"wxt"
	],
	"author": "DoodleBears",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/DoodleBears/ContextBro/issues"
	},
	"homepage": "https://github.com/DoodleBears/ContextBro#readme",
	"dependencies": {
		"@radix-ui/react-checkbox": "^1.3.3",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-switch": "^1.2.6",
		"@radix-ui/react-tabs": "^1.1.13",
		"@radix-ui/react-tooltip": "^1.2.8",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"dayjs": "^1.11.19",
		"defuddle": "^0.7.0",
		"lucide-react": "^0.575.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwind-merge": "^3.5.0",
		"turndown": "^7.2.2",
		"turndown-plugin-gfm": "^1.0.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@tailwindcss/vite": "^4.2.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/turndown": "^5.0.6",
		"@wxt-dev/module-react": "^1.1.5",
		"tailwindcss": "^4.2.0",
		"typescript": "^5.9.3",
		"wxt": "^0.20.17"
	}
}
