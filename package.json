{
  "name": "context-bro",
  "version": "0.1.0",
  "description": "Browser context provider for AI agents — Web Clipper for AI",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DoodleBears/ContextBro.git"
  },
  "keywords": [
    "browser-extension",
    "web-clipper",
    "ai-agent",
    "context-provider",
    "wxt"
  ],
  "author": "DoodleBears",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/DoodleBears/ContextBro/issues"
  },
  "homepage": "https://github.com/DoodleBears/ContextBro#readme",
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.5",
    "typescript": "^5.9.3",
    "wxt": "^0.20.17"
  }
}
