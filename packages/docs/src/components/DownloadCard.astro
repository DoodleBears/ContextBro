---
import type { HTMLAttributes } from 'astro/types'
import chromeIcon from '../assets/icon-chrome.svg'
import firefoxIcon from '../assets/icon-firefox.svg'

interface Props extends Omit<HTMLAttributes<'a'>, 'title'> {
  title: string
  description?: string
  icon: 'chrome' | 'firefox'
}

const icons = { chrome: chromeIcon, firefox: firefoxIcon }
const { title, description, icon, ...attributes } = Astro.props
const iconSrc = icons[icon].src
---

<div class="sl-link-card download-card">
  <span class="sl-flex stack">
    <a {...attributes}>
      <span class="title-row">
        <img src={iconSrc} alt="" width="20" height="20" class="browser-icon" />
        <span class="title" set:html={title} />
      </span>
    </a>
    {description && <span class="description" set:html={description} />}
  </span>
  <svg aria-hidden="true" class="icon rtl:flip" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="m14.707 5.636-1.414 1.414L18.242 12l-4.95 4.95 1.415 1.414L21.07 12l-6.364-6.364Z"/><path d="M3.293 11h15.414v2H3.293z"/></svg>
</div>

<style>
  @layer starlight.components {
    .download-card {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 0.5rem;
      border: 1px solid var(--sl-color-gray-5);
      border-radius: 0.5rem;
      padding: 1rem;
      box-shadow: var(--sl-shadow-sm);
      position: relative;
    }

    a {
      text-decoration: none;
      line-height: var(--sl-line-height-headings);
    }

    a::before {
      content: '';
      position: absolute;
      inset: 0;
    }

    .stack {
      flex-direction: column;
      gap: 0.5rem;
    }

    .title-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .browser-icon {
      flex-shrink: 0;
      width: 20px;
      height: 20px;
    }

    .title {
      color: var(--sl-color-white);
      font-weight: 600;
      font-size: var(--sl-text-lg);
    }

    .description {
      color: var(--sl-color-gray-3);
      line-height: 1.5;
    }

    .icon {
      color: var(--sl-color-gray-3);
    }

    .download-card:hover {
      background: var(--sl-color-gray-7, var(--sl-color-gray-6));
      border-color: var(--sl-color-gray-2);
    }

    .download-card:hover .icon {
      color: var(--sl-color-white);
    }
  }
</style>
